# ── LeadFlow configuration ──
# Copy this file to ".env" and fill in your values. Everything here can also be
# set later from the admin Settings page (stored in the database).

# Server
PORT=3100
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# First admin account (created on first boot only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Section passwords (second-factor lock for the inbox / leads)
WHATSAPP_PASSWORD=changeme
LEADS_PASSWORD=changeme

# Database file location (optional — defaults to ./data/leadflow.sqlite)
# DB_PATH=/absolute/path/to/leadflow.sqlite

# ── Meta / WhatsApp (can also be set in admin → Settings) ──
# Get these from developers.facebook.com → your app → WhatsApp
# WHATSAPP_PHONE_ID=
# WHATSAPP_TOKEN=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_ID=
# WHATSAPP_APP_SECRET=

# ── AI auto-reply (optional — set whichever provider you use) ──
# Free tiers available for Gemini and Groq. Claude is a paid fallback.
# GEMINI_API_KEY=
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=
